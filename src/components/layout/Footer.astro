---
import AnalogClock from '../../components/ui/AnalogClock.astro';
import SocialLinks from '../../components/content/SocialLinks.astro';

const currentYear = new Date().getFullYear();

const { pathname } = Astro.url
const pathSegments = pathname.split("/").filter(Boolean)
const highlightedPath = pathSegments.length <= 1 ? pathname : `/${pathSegments[0]}`;

const isActive = (href: string) => {
  if (href === "/") return pathname === "/";
  return highlightedPath === href;
};

const footerLinks = [
  { name: "Home", href: "/" },
  { name: "Notes", href: "/notes" },
  { name: "Scratch", href: "/scratch" },
  { name: "Work", href: "/work" },
  { name: "Now", href: "/now" },
  { name: "About", href: "/about" },
  { name: "Uses", href: "/uses" },
  { name: "Books", href: "/books" },
  { name: "Newsletter", href: "/newsletter" },
]

const row1 = footerLinks.slice(0, 5)
const row2 = footerLinks.slice(5)
---

<footer class="border-border bg-background mt-auto w-full border-t">
  <div class="mx-auto max-w-3xl px-4 py-6 md:px-6">
    <div class="flex flex-col items-center md:items-start gap-4">

      {/* Social Links */}
      <SocialLinks />

      {/* Nav Links */}
      <nav class="flex flex-col md:flex-row gap-y-1 md:gap-x-4">
        <div class="flex flex-wrap justify-center md:justify-start gap-x-4">
          {row1.map((link) => (
            <a
              href={link.href}
              class={`transition-colors no-underline ${isActive(link.href) ? "text-foreground" : "text-muted-foreground hover:text-foreground"}`}
            >
              {link.name}
            </a>
          ))}
        </div>
        <div class="flex flex-wrap justify-center md:justify-start gap-x-4">
          {row2.map((link) => (
            <a
              href={link.href}
              class={`transition-colors no-underline ${isActive(link.href) ? "text-foreground" : "text-muted-foreground hover:text-foreground"}`}
            >
              {link.name}
            </a>
          ))}
        </div>
      </nav>

      {/* Newsletter link — form lives on /newsletter page */}

      {/* Bottom row: clock + copyright */}
      <div class="flex items-center justify-between w-full mt-1">
        <p class="text-muted-foreground">
          &copy; {currentYear} Yash Agarwal
        </p>
        <AnalogClock />
      </div>

    </div>
  </div>
</footer>
