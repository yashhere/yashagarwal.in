---
import { Icon } from 'astro-icon/components'

import { getSeriesNotes } from "../../lib/content"

interface Props {
  series: {
    title: string
    order?: number
  }
  currentSlug: string
}

const { series, currentSlug } = Astro.props

const seriesNotes = await getSeriesNotes(series.title)
const currentIndex = seriesNotes.findIndex((n) => n.slug === currentSlug)
const displayIndex = currentIndex + 1
---

<div
  class="border-border rounded border p-2.5 text-sm"
  x-data="{ isOpen: false }"
>
  <button
    class="flex w-full items-center justify-between text-left cursor-pointer bg-transparent border-0 p-0"
    @click="isOpen = !isOpen"
    :aria-expanded="isOpen"
  >
    <span class="text-foreground font-medium">
      {series.title} <span class="text-muted-foreground font-normal">({displayIndex}/{seriesNotes.length})</span>
    </span>
    <Icon
      name="lucide:chevron-down"
      class="text-muted-foreground h-3 w-3 transition-transform duration-200"
      :class="isOpen && 'rotate-180'"
    />
  </button>

  <div
    class="grid transition-[grid-template-rows] duration-200 ease-in-out"
    :class="isOpen ? 'grid-rows-[1fr]' : 'grid-rows-[0fr]'"
  >
    <div class="overflow-hidden">
      <ul class="border-border mt-2 space-y-1 border-t pt-2">
        {seriesNotes.map((note) => {
          const isCurrent = note.slug === currentSlug
          const isPublished = note.data.status === "published"
          return (
            <li>
              {isPublished ? (
                isCurrent ? (
                  <span class="text-foreground">{note.data.title}</span>
                ) : (
                  <a href={`/notes/${note.slug}`} class="text-muted-foreground hover:text-foreground transition-colors no-underline">
                    {note.data.title}
                  </a>
                )
              ) : (
                <span class="text-muted-foreground/40">{note.data.title}</span>
              )}
            </li>
          )
        })}
      </ul>
    </div>
  </div>
</div>
