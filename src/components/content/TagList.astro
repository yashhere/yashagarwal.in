---
interface Props {
  tags?: string[];
}

import GithubSlugger from 'github-slugger';
import { Icon } from 'astro-icon/components';
const { tags } = Astro.props;
---

{tags && tags.length > 0 && (
  <div class="border-border rounded border p-2 text-sm my-6">
    <div class="flex items-center gap-1.5 mb-2">
      <Icon name="lucide:tag" class="text-muted-foreground h-3 w-3" />
      <span class="text-muted-foreground text-xs">Tags</span>
    </div>
    <div class="border-border flex flex-wrap gap-1.5 border-t pt-2">
      {tags.map((tag) => {
        const slugger = new GithubSlugger();
        const tag_slug = slugger.slug(tag);
        return (
          <a
            href={`/tags/${tag_slug}`}
            class="bg-muted/50 text-muted-foreground hover:bg-muted hover:text-foreground inline-flex items-center rounded px-1.5 py-0.5 text-xs transition-[color,transform] duration-150 active:scale-[0.97] no-underline"
          >
            {tag}
          </a>
        );
      })}
    </div>
  </div>
)}
