---
import { Icon } from 'astro-icon/components'

import { cn } from "../../lib/utils"

interface Props {
  title: string
  class?: string
  [key: string]: any
}

const { title, class: className, ...props } = Astro.props
---

<div
  x-data="{ open: false }"
  class={cn(
    "border-border bg-card my-4 rounded-lg border",
    className
  )}
  {...props}
>
  <button
    @click="open = !open"
    class="text-foreground hover:bg-muted/50 focus-visible:ring-ring flex w-full cursor-pointer items-center gap-2 p-4 font-medium text-left transition-colors focus-visible:ring-2 focus-visible:outline-none"
  >
    <Icon
      name="lucide:chevron-right"
      class="text-muted-foreground h-4 w-4 shrink-0 transition-transform duration-200"
      :class="{ 'rotate-90': open }"
    />
    <span class="flex-1">{title}</span>
  </button>
  <div x-show="open" x-collapse.duration.300ms>
    <div class="text-muted-foreground px-4 pt-0 pb-4 leading-relaxed">
      <div class="pl-6">
        <slot />
      </div>
    </div>
  </div>
</div>
