---
import { format } from 'date-fns';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
  homePage?: boolean;
  index?: number;
}

const { note, homePage = false, index = 0 } = Astro.props;
const formattedDate = format(note.data.createdOn, 'MM/yy');
---

{homePage ? (
  <div class="flex flex-col py-1">
    <a
      href={`/notes/${note.slug}`}
      class="group hover:bg-accent flex w-full flex-col items-start gap-1 rounded-lg p-3 text-left transition-colors"
    >
      <div class="flex w-full items-baseline justify-between gap-3">
        <span class="text-foreground group-hover:text-primary font-sans text-base font-medium transition-colors" data-note-title>
          {note.data.title}
        </span>
        <span class="text-muted-foreground shrink-0 font-mono text-sm">
          {formattedDate}
        </span>
      </div>
      {note.data.description && (
        <p class="text-muted-foreground line-clamp-2 max-w-[85%] text-sm leading-relaxed">
          {note.data.description}
        </p>
      )}
    </a>
  </div>
) : (
  <li class="flex items-baseline gap-3 py-1 px-0.5">
    <span class="text-muted-foreground/60 shrink-0 tabular-nums text-xs w-5 text-right">{index}</span>
    <a
      href={`/notes/${note.slug}`}
      class="text-foreground min-w-0 flex-1 no-underline hover:underline"
      data-note-title
      data-note-description={note.data.description || ''}
      data-note-tags={note.data.tags?.join(' ') || ''}
      data-note-category={note.data.category || ''}
    >
      {note.data.title}
    </a>
    <span class="text-muted-foreground shrink-0 font-mono text-xs">
      {formattedDate}
    </span>
  </li>
)}
