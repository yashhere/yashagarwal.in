---
import { Icon } from 'astro-icon/components';

const socialLinks = [
  {
    name: "Email",
    href: "mailto:hello@yashagarwal.in",
    icon: "lucide:mail",
  },
  {
    name: "X",
    href: "https://x.com/its_yash_btw",
    icon: "simple-icons:x",
  },
  {
    name: "GitHub",
    href: "https://github.com/yashhere",
    icon: "simple-icons:github",
  },
  {
    name: "LinkedIn",
    href: "https://www.linkedin.com/in/theyashagarwal/",
    icon: "simple-icons:linkedin",
  },
  {
    name: "RSS",
    href: "/rss.xml",
    icon: "lucide:rss",
  },
]
---

<div class="flex items-center gap-3">
  {
    socialLinks.map((social, i) => (
      <a
        href={social.href}
        class={`text-muted-foreground hover:text-foreground rounded px-1 py-1.5 transition-[color,transform] duration-200 hover:scale-110 hover:-translate-y-0.5 no-underline ${i === 0 ? '-ml-1' : ''}`}
        aria-label={social.name}
        target={social.name === "Email" ? undefined : "_blank"}
        rel={social.name === "Email" ? undefined : "noopener noreferrer"}
      >
        <Icon name={social.icon} class="h-4 w-4" />
      </a>
    ))
  }
</div>
