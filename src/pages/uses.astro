---
import Heading from "../components/ui/Heading.astro"
import BaseLayout from "../layouts/BaseLayout.astro"
---

<BaseLayout
  title="Uses"
  description="Hardware, software, and tools that Yash uses."
>
  <Heading level="h2" as="h1" class="mt-6 mb-6">Uses</Heading>

  <p class="text-muted-foreground text-sm mb-6">
    A list of tools and hardware I own.
    Inspired by <a href="https://uses.tech/" target="_blank" rel="noopener noreferrer">uses.tech</a>.
  </p>

  <div class="space-y-8">
    <div>
      <Heading level="h3" as="h2" class="mb-3">Hardware</Heading>
      <ul class="space-y-2 list-none pl-0">
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Phone</span>
          <span>Motorola Edge 50 Neo</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Laptop</span>
          <span>MacBook Pro M4, work provided. Very powerful. I don't use it for personal projects.</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Desktop</span>
          <span>Mac Mini M4, my personal machine for side projects and experiments.</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Audio</span>
          <span>Sony WI-XB400</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Monitor</span>
          <span>LG 27UL550</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Keyboard</span>
          <span>Apple Magic Keyboard</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-28">Mouse</span>
          <span>Apple Magic Mouse</span>
        </li>
      </ul>
    </div>

    <div>
      <Heading level="h3" as="h2" class="mb-3">Software</Heading>
      <ul class="space-y-2 list-none pl-0">
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Editor</span>
          <span>VS Code with minimal plugins</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Terminal</span>
          <span>iTerm2 with fish shell</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Font</span>
          <span>JetBrains Mono</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Browser</span>
          <span>Brave</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Notes</span>
          <span>Obsidian, local first, plain text</span>
        </li>
        <li class="flex items-baseline gap-3">
          <span class="text-muted-foreground shrink-0 text-sm w-32">Reading</span>
          <span>Kindle and physical books</span>
        </li>
      </ul>
    </div>
  </div>
</BaseLayout>
