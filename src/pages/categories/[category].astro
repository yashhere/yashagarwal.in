---
import GithubSlugger from "github-slugger"

import Heading from "../../components/ui/Heading.astro"
import NotePreview from "../../components/content/NotePreview.astro"
import BaseLayout from "../../layouts/BaseLayout.astro"
import { getPreviewNotes, getNoteNumbers } from "../../lib/content"

export async function getStaticPaths() {
  const notes = await getPreviewNotes()
  const allCategories = new Set<string>()
  notes.forEach((note) => {
    if (note.data.category) allCategories.add(note.data.category)
  })
  const slugger = new GithubSlugger()
  return Array.from(allCategories).map((category) => {
    const slug = slugger.slug(category)
    return { params: { category: slug }, props: { categoryName: category } }
  })
}

const { categoryName } = Astro.props
const { category } = Astro.params

const allNotes = await getPreviewNotes()
const noteNumbers = await getNoteNumbers()
const filteredNotes = allNotes.filter((note) => {
  if (!note.data.category) return false
  const slugger = new GithubSlugger()
  return slugger.slug(note.data.category) === category
})
---

<BaseLayout title={categoryName} description={`Notes in category ${categoryName}`} mainClass="mx-auto w-full max-w-3xl pb-12 px-4 md:px-6">
  <Heading level="h2" as="h1" class="mt-6 mb-4">{categoryName}</Heading>

  <ul>
    {filteredNotes.map((note, i) => (
      <NotePreview note={note} index={noteNumbers.get(note.slug)} />
    ))}
  </ul>
</BaseLayout>
